{
  "manifest_version": 3,
  "name": "Quick Translator",
  "version": "1.0",
  "description": "選取文字即時翻譯",
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://translate.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "all_frames": true
    }
  ]
}
